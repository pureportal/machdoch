{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "vitest/globals"],
    "incremental": true,
    "tsBuildInfoFile": "./.cache/tsconfig.test.tsbuildinfo"
  },
  "include": [
    "src/**/__test__/**/*.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ],
  "exclude": [
    "src/tauri/ui/**/*.ts",
    "src/tauri/ui/**/*.tsx"
  ]
}
