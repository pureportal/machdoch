{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://machdoch.local/schemas/runtime-config.schema.json",
  "title": "MachdochRuntimeConfigContract",
  "description": "Shared runtime configuration, user settings, and desktop snapshot contract for TypeScript and Rust.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "workspaceConfig": {
      "$ref": "#/$defs/WorkspaceConfigFile"
    },
    "userConfig": {
      "$ref": "#/$defs/UserConfigFile"
    },
    "runtimeConfig": {
      "$ref": "#/$defs/RuntimeConfig"
    },
    "runtimeSnapshot": {
      "$ref": "#/$defs/RuntimeSnapshot"
    },
    "userDesktopSettings": {
      "$ref": "#/$defs/UserDesktopSettings"
    }
  },
  "$defs": {
    "RunMode": {
      "type": "string",
      "enum": ["ask", "machdoch"]
    },
    "ReasoningMode": {
      "type": "string",
      "enum": [
        "default",
        "none",
        "minimal",
        "low",
        "medium",
        "high",
        "xhigh",
        "max",
        "ultra"
      ]
    },
    "ToolName": {
      "type": "string",
      "enum": [
        "filesystem",
        "shell",
        "network",
        "browser",
        "git",
        "packages",
        "mcp",
        "scheduler",
        "utilities"
      ]
    },
    "ConfiguredModelProvider": {
      "type": "string",
      "enum": [
        "openai",
        "anthropic",
        "google",
        "langdock",
        "codex-cli",
        "claude-cli",
        "copilot-cli"
      ]
    },
    "ModelProvider": {
      "type": "string",
      "enum": [
        "openai",
        "anthropic",
        "google",
        "langdock",
        "codex-cli",
        "claude-cli",
        "copilot-cli",
        "unconfigured"
      ]
    },
    "UserApiProvider": {
      "type": "string",
      "enum": ["openai", "anthropic", "google", "langdock", "quiver", "recraft"]
    },
    "AgentCliProvider": {
      "type": "string",
      "enum": ["codex-cli", "claude-cli", "copilot-cli"]
    },
    "WebSearchProvider": {
      "type": "string",
      "enum": ["none", "perplexity", "tavily", "serper"]
    },
    "UserWebSearchProvider": {
      "type": "string",
      "enum": ["perplexity", "tavily", "serper"]
    },
    "AudioProvider": {
      "type": "string",
      "enum": ["openai", "google"]
    },
    "VoiceAiProvider": {
      "type": "string",
      "enum": ["none", "openai", "google"]
    },
    "RuntimeMemoryScope": {
      "type": "string",
      "enum": ["session", "global"]
    },
    "UserReviewModelMode": {
      "type": "string",
      "enum": ["base", "dedicated"]
    },
    "WorkspaceCompatibilityConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "discoverGithubCustomizations": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "RuntimeAgentLimitOverrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "infinite": {
          "type": "boolean",
          "default": false
        },
        "executorTurns": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "autopilotExecutorIterations": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      }
    },
    "RuntimeAgentLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executorTurns", "autopilotExecutorIterations"],
      "properties": {
        "executorTurns": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 1000
        },
        "autopilotExecutorIterations": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 100
        }
      }
    },
    "WorkspaceConfigFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultMode": {
          "$ref": "#/$defs/RunMode"
        },
        "provider": {
          "$ref": "#/$defs/ConfiguredModelProvider"
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "reasoning": {
          "$ref": "#/$defs/ReasoningMode"
        },
        "offline": {
          "type": "boolean"
        },
        "agentLimits": {
          "$ref": "#/$defs/RuntimeAgentLimitOverrides"
        },
        "compatibility": {
          "$ref": "#/$defs/WorkspaceCompatibilityConfig"
        }
      }
    },
    "ProviderAvailability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "configured"],
      "properties": {
        "provider": {
          "$ref": "#/$defs/ConfiguredModelProvider"
        },
        "configured": {
          "type": "boolean"
        }
      }
    },
    "WebSearchProviderAvailability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "configured"],
      "properties": {
        "provider": {
          "$ref": "#/$defs/UserWebSearchProvider"
        },
        "configured": {
          "type": "boolean"
        }
      }
    },
    "AudioProviderAvailability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "configured"],
      "properties": {
        "provider": {
          "$ref": "#/$defs/AudioProvider"
        },
        "configured": {
          "type": "boolean"
        }
      }
    },
    "RuntimeWebSearchConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["activeProvider", "providerAvailability"],
      "properties": {
        "activeProvider": {
          "$ref": "#/$defs/WebSearchProvider"
        },
        "providerAvailability": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/WebSearchProviderAvailability"
          }
        }
      }
    },
    "RuntimeReviewModelConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "$ref": "#/$defs/UserReviewModelMode",
          "default": "base"
        },
        "provider": {
          "$ref": "#/$defs/ConfiguredModelProvider"
        },
        "model": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "RuntimeMemoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "scope", "content", "createdAt", "updatedAt"],
      "properties": {
        "id": {
          "type": "string"
        },
        "scope": {
          "$ref": "#/$defs/RuntimeMemoryScope"
        },
        "content": {
          "type": "string"
        },
        "createdAt": {
          "type": "integer",
          "minimum": 0
        },
        "updatedAt": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "UserProviderApiKeys": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "openai": {
          "type": "string"
        },
        "anthropic": {
          "type": "string"
        },
        "google": {
          "type": "string"
        },
        "langdock": {
          "type": "string"
        },
        "quiver": {
          "type": "string"
        },
        "recraft": {
          "type": "string"
        }
      }
    },
    "UserAgentCliPaths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "codex-cli": {
          "type": "string"
        },
        "claude-cli": {
          "type": "string"
        },
        "copilot-cli": {
          "type": "string"
        }
      }
    },
    "UserWebSearchApiKeys": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "perplexity": {
          "type": "string"
        },
        "tavily": {
          "type": "string"
        },
        "serper": {
          "type": "string"
        }
      }
    },
    "UserWebSearchConfigFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "activeProvider": {
          "$ref": "#/$defs/WebSearchProvider"
        },
        "apiKeys": {
          "$ref": "#/$defs/UserWebSearchApiKeys"
        }
      }
    },
    "UserVoiceConfigFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "activeProvider": {
          "$ref": "#/$defs/VoiceAiProvider"
        }
      }
    },
    "UserSpeechToTextConfigFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "activeProvider": {
          "$ref": "#/$defs/VoiceAiProvider"
        },
        "inputDeviceId": {
          "type": "string"
        }
      }
    },
    "UserMemoryConfigFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "globalEnabled": {
          "type": "boolean",
          "default": false
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RuntimeMemoryEntry"
          }
        }
      }
    },
    "UserReviewModelConfigFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "$ref": "#/$defs/UserReviewModelMode"
        },
        "provider": {
          "$ref": "#/$defs/ConfiguredModelProvider"
        },
        "model": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "UserReviewModelSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "$ref": "#/$defs/UserReviewModelMode",
          "default": "base"
        },
        "provider": {
          "$ref": "#/$defs/ConfiguredModelProvider"
        },
        "model": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "UserAgentLimitsSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["infinite", "executorTurns", "autopilotExecutorIterations"],
      "properties": {
        "infinite": {
          "type": "boolean",
          "default": false
        },
        "executorTurns": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 64
        },
        "autopilotExecutorIterations": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 16
        }
      }
    },
    "UserDesktopConfigFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "autostartMinimized": {
          "type": "boolean"
        },
        "autostartToTray": {
          "type": "boolean"
        },
        "alwaysRunAsAdministrator": {
          "type": "boolean"
        },
        "assistantBubbleEnabled": {
          "type": "boolean"
        },
        "assistantBubbleHideWhenFullscreen": {
          "type": "boolean"
        },
        "assistantBubbleTemporarilyHideSeconds": {
          "type": "integer",
          "minimum": 2,
          "maximum": 30
        },
        "aiContextMaxMessages": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200
        },
        "inactiveSessionArchiveDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365
        },
        "archivedSessionRetentionDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365
        },
        "quickVoiceEnabled": {
          "type": "boolean"
        },
        "quickVoiceShortcut": {
          "type": "string"
        },
        "quickVoiceSilenceSeconds": {
          "type": "number",
          "minimum": 0.8,
          "maximum": 8.0
        },
        "quickVoiceMaxMessages": {
          "type": "integer",
          "minimum": 10,
          "maximum": 200
        }
      }
    },
    "UserDesktopSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "autostartEnabled",
        "autostartMinimized",
        "autostartToTray",
        "alwaysRunAsAdministrator",
        "assistantBubbleEnabled",
        "assistantBubbleHideWhenFullscreen",
        "assistantBubbleTemporarilyHideSeconds",
        "aiContextMaxMessages",
        "inactiveSessionArchiveDays",
        "archivedSessionRetentionDays",
        "quickVoiceEnabled",
        "quickVoiceShortcut",
        "quickVoiceSilenceSeconds",
        "quickVoiceMaxMessages"
      ],
      "properties": {
        "autostartEnabled": {
          "type": "boolean",
          "default": false
        },
        "autostartMinimized": {
          "type": "boolean",
          "default": false
        },
        "autostartToTray": {
          "type": "boolean",
          "default": false
        },
        "alwaysRunAsAdministrator": {
          "type": "boolean",
          "default": false
        },
        "assistantBubbleEnabled": {
          "type": "boolean",
          "default": true
        },
        "assistantBubbleHideWhenFullscreen": {
          "type": "boolean",
          "default": true
        },
        "assistantBubbleTemporarilyHideSeconds": {
          "type": "integer",
          "minimum": 2,
          "maximum": 30,
          "default": 6
        },
        "aiContextMaxMessages": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200,
          "default": 60
        },
        "inactiveSessionArchiveDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365,
          "default": 7
        },
        "archivedSessionRetentionDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365,
          "default": 7
        },
        "quickVoiceEnabled": {
          "type": "boolean",
          "default": true
        },
        "quickVoiceShortcut": {
          "type": "string",
          "default": "CommandOrControl+Alt+V"
        },
        "quickVoiceSilenceSeconds": {
          "type": "number",
          "minimum": 0.8,
          "maximum": 8.0,
          "default": 1.8
        },
        "quickVoiceMaxMessages": {
          "type": "integer",
          "minimum": 10,
          "maximum": 200,
          "default": 50
        }
      }
    },
    "ProviderEnrollmentInstructionsConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["native-when-available"] },
        "unmanagedNative": { "type": "string", "enum": ["adopt", "allow", "fail"] },
        "strictConflicts": { "type": "boolean" },
        "fallback": { "type": "string", "enum": ["automatic"] },
        "failOnTruncation": { "type": "boolean" }
      }
    },
    "ProviderEnrollmentMcpConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["direct-native"] },
        "fallback": { "type": "string", "enum": ["per-server-stdio-proxy"] },
        "compatibilityServerName": { "type": "string", "minLength": 1 },
        "unmanagedNative": { "type": "string", "enum": ["adopt", "allow", "fail"] },
        "approvals": { "type": "string", "enum": ["never"] },
        "progressiveDiscoveryThresholdPercent": { "type": "number", "minimum": 1, "maximum": 5 }
      }
    },
    "ProviderEnrollmentPersistentSyncConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "watch": { "type": "boolean" },
        "daemonAtLogin": { "type": "boolean" },
        "debounceMs": { "type": "integer", "minimum": 50, "maximum": 60000 },
        "filesystemConvergenceTargetMs": { "type": "integer", "minimum": 100, "maximum": 60000 },
        "fullRescanIntervalMs": { "type": "integer", "minimum": 10000, "maximum": 86400000 },
        "autoReloadOwnedSessions": { "type": "boolean" }
      }
    },
    "ProviderEnrollmentProviderConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "ProviderEnrollmentProvidersConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "codex-cli": { "$ref": "#/$defs/ProviderEnrollmentProviderConfig" },
        "claude-cli": { "$ref": "#/$defs/ProviderEnrollmentProviderConfig" },
        "copilot-cli": { "$ref": "#/$defs/ProviderEnrollmentProviderConfig" }
      }
    },
    "ProviderEnrollmentConfigFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schemaVersion": { "type": "integer", "const": 1 },
        "enabled": { "type": "boolean" },
        "instructions": { "$ref": "#/$defs/ProviderEnrollmentInstructionsConfig" },
        "mcp": { "$ref": "#/$defs/ProviderEnrollmentMcpConfig" },
        "persistentSync": { "$ref": "#/$defs/ProviderEnrollmentPersistentSyncConfig" },
        "providers": { "$ref": "#/$defs/ProviderEnrollmentProvidersConfig" }
      }
    },
    "UserConfigFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "apiKeys": {
          "$ref": "#/$defs/UserProviderApiKeys"
        },
        "webSearch": {
          "$ref": "#/$defs/UserWebSearchConfigFile"
        },
        "voice": {
          "$ref": "#/$defs/UserVoiceConfigFile"
        },
        "speechToText": {
          "$ref": "#/$defs/UserSpeechToTextConfigFile"
        },
        "desktop": {
          "$ref": "#/$defs/UserDesktopConfigFile"
        },
        "agentLimits": {
          "$ref": "#/$defs/RuntimeAgentLimitOverrides"
        },
        "memory": {
          "$ref": "#/$defs/UserMemoryConfigFile"
        },
        "reviewModel": {
          "$ref": "#/$defs/UserReviewModelConfigFile"
        },
        "agentCliPaths": {
          "$ref": "#/$defs/UserAgentCliPaths"
        },
        "providerEnrollment": {
          "$ref": "#/$defs/ProviderEnrollmentConfigFile"
        }
      }
    },
    "UiControlAvailability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "available",
        "platform",
        "supportsScreenshots",
        "supportsWindowEnumeration",
        "supportsInput",
        "supportsWindowHandles"
      ],
      "properties": {
        "available": {
          "type": "boolean"
        },
        "platform": {
          "type": "string",
          "enum": ["windows", "macos", "linux", "unknown"]
        },
        "supportsScreenshots": {
          "type": "boolean"
        },
        "supportsWindowEnumeration": {
          "type": "boolean"
        },
        "supportsInput": {
          "type": "boolean"
        },
        "supportsWindowHandles": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "RuntimeConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspaceRoot",
        "mode",
        "provider",
        "model",
        "reasoning",
        "offline",
        "compatibility",
        "providerAvailability",
        "webSearch",
        "reviewModel"
      ],
      "properties": {
        "workspaceRoot": {
          "type": "string"
        },
        "workspaceConfigPath": {
          "type": "string"
        },
        "userConfigPath": {
          "type": "string"
        },
        "mode": {
          "$ref": "#/$defs/RunMode"
        },
        "provider": {
          "$ref": "#/$defs/ModelProvider"
        },
        "model": {
          "type": "string"
        },
        "reasoning": {
          "$ref": "#/$defs/ReasoningMode"
        },
        "offline": {
          "type": "boolean"
        },
        "agentLimits": {
          "$ref": "#/$defs/RuntimeAgentLimits"
        },
        "compatibility": {
          "$ref": "#/$defs/WorkspaceCompatibilityConfig"
        },
        "providerAvailability": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProviderAvailability"
          }
        },
        "webSearch": {
          "$ref": "#/$defs/RuntimeWebSearchConfig"
        },
        "reviewModel": {
          "$ref": "#/$defs/RuntimeReviewModelConfig"
        }
      }
    },
    "RuntimeSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspaceRoot",
        "defaultMode",
        "defaultReasoning",
        "mode",
        "provider",
        "model",
        "reasoning",
        "offline",
        "agentLimits",
        "compatibility",
        "providerAvailability",
        "webSearch",
        "reviewModel"
      ],
      "properties": {
        "workspaceRoot": {
          "type": "string"
        },
        "workspaceConfigPath": {
          "type": "string"
        },
        "defaultMode": {
          "$ref": "#/$defs/RunMode"
        },
        "defaultReasoning": {
          "$ref": "#/$defs/ReasoningMode"
        },
        "mode": {
          "$ref": "#/$defs/RunMode"
        },
        "provider": {
          "$ref": "#/$defs/ModelProvider"
        },
        "model": {
          "type": "string"
        },
        "reasoning": {
          "$ref": "#/$defs/ReasoningMode"
        },
        "offline": {
          "type": "boolean"
        },
        "agentLimits": {
          "$ref": "#/$defs/RuntimeAgentLimits"
        },
        "compatibility": {
          "$ref": "#/$defs/WorkspaceCompatibilityConfig"
        },
        "providerAvailability": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProviderAvailability"
          }
        },
        "webSearch": {
          "$ref": "#/$defs/RuntimeWebSearchConfig"
        },
        "reviewModel": {
          "$ref": "#/$defs/RuntimeReviewModelConfig"
        },
        "uiControl": {
          "$ref": "#/$defs/UiControlAvailability"
        }
      }
    }
  },
  "x-machdoch": {
    "schemaVersion": 1,
    "defaultModelProvider": "openai",
    "defaultModelByProvider": {
      "openai": "gpt-5.5",
      "anthropic": "claude-sonnet-5",
      "google": "gemini-3.5-flash",
      "langdock": "gpt-5.5",
      "codex-cli": "gpt-5.5",
      "claude-cli": "sonnet",
      "copilot-cli": "auto"
    },
    "runtimeEnvKeys": [
      "MACHDOCH_MODE",
      "MACHDOCH_MODEL",
      "MACHDOCH_REASONING",
      "MACHDOCH_OFFLINE",
      "MACHDOCH_WEB_SEARCH_PROVIDER",
      "MACHDOCH_EXECUTOR_TURNS",
      "MACHDOCH_AUTOPILOT_ITERATIONS",
      "MACHDOCH_INFINITE",
      "MACHDOCH_CODEX_CLI_PATH",
      "MACHDOCH_CLAUDE_CLI_PATH",
      "MACHDOCH_COPILOT_CLI_PATH",
      "LANGDOCK_REGION",
      "LANGDOCK_BASE_URL"
    ],
    "providerEnvKeys": {
      "openai": "OPENAI_API_KEY",
      "anthropic": "ANTHROPIC_API_KEY",
      "google": "GOOGLE_API_KEY",
      "langdock": "LANGDOCK_API_KEY",
      "quiver": "QUIVERAI_API_KEY",
      "recraft": "RECRAFT_API_KEY"
    },
    "agentCliProviderEnvKeys": {
      "codex-cli": "MACHDOCH_CODEX_CLI_PATH",
      "claude-cli": "MACHDOCH_CLAUDE_CLI_PATH",
      "copilot-cli": "MACHDOCH_COPILOT_CLI_PATH"
    },
    "webSearchEnvKeys": {
      "perplexity": "PERPLEXITY_API_KEY",
      "tavily": "TAVILY_API_KEY",
      "serper": "SERPER_API_KEY"
    }
  }
}
