{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "machdoch",
  "version": "0.37.2",
  "identifier": "com.machdoch.desktop",
  "build": {
    "beforeDevCommand": {
      "cwd": "..",
      "script": "npm run build:cli-bundle && npm run dev:ui"
    },
    "beforeBuildCommand": {
      "cwd": "..",
      "script": "npm run build:cli-bundle && npm run build:ui"
    },
    "devUrl": "http://127.0.0.1:4173",
    "frontendDist": "../dist/ui-preview"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        "default"
      ]
    },
    "windows": [
      {
        "label": "main",
        "title": "machdoch",
        "width": 1440,
        "height": 960,
        "minWidth": 960,
        "minHeight": 720,
        "center": true,
        "visible": false,
        "preventOverflow": {
          "width": 24,
          "height": 24
        },
        "resizable": true,
        "skipTaskbar": false,
        "decorations": false,
        "transparent": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "resources": [
      "python/media_diffusers_worker.py",
      "python/media_diffusers_requirements.txt"
    ],
    "targets": [
      "msi",
      "nsis",
      "deb",
      "rpm",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
