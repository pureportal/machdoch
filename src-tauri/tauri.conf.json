{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "machdoch",
  "version": "0.1.0",
  "identifier": "com.machdoch.desktop",
  "build": {
    "beforeDevCommand": {
      "cwd": "..",
      "script": "npm run dev:ui"
    },
    "beforeBuildCommand": {
      "cwd": "..",
      "script": "npm run build:ui"
    },
    "devUrl": "http://127.0.0.1:4173",
    "frontendDist": "../dist/ui-preview"
  },
  "app": {
    "security": {
      "capabilities": ["default"]
    },
    "windows": [
      {
        "label": "main",
        "title": "machdoch",
        "width": 1440,
        "height": 960,
        "minWidth": 960,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb", "rpm", "appimage"]
  }
}
