{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "machdoch",
  "version": "0.5.3",
  "identifier": "com.machdoch.desktop",
  "build": {
    "beforeDevCommand": {
      "cwd": "..",
      "script": "npm run dev:ui"
    },
    "beforeBuildCommand": {
      "cwd": "..",
      "script": "npm run build:cli-bundle && npm run build:ui"
    },
    "devUrl": "http://127.0.0.1:4173",
    "frontendDist": "../dist/ui-preview"
  },
  "app": {
    "security": {
      "capabilities": [
        "default"
      ]
    },
    "windows": [
      {
        "label": "main",
        "title": "machdoch",
        "width": 1440,
        "height": 960,
        "minWidth": 960,
        "minHeight": 720,
        "center": true,
        "visible": false,
        "resizable": true,
        "decorations": false,
        "transparent": false
      },
      {
        "label": "assistant-bubble",
        "title": "machdoch Assistant Bubble",
        "width": 84,
        "height": 84,
        "minWidth": 84,
        "minHeight": 84,
        "visible": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "preventOverflow": {
          "width": 24,
          "height": 24
        }
      },
      {
        "label": "assistant-popup",
        "title": "machdoch Assistant Popup",
        "width": 448,
        "height": 720,
        "minWidth": 448,
        "minHeight": 620,
        "visible": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "preventOverflow": {
          "width": 24,
          "height": 24
        }
      },
      {
        "label": "quick-voice",
        "title": "machdoch Quick Voice",
        "width": 380,
        "height": 220,
        "minWidth": 380,
        "minHeight": 220,
        "visible": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "preventOverflow": {
          "width": 24,
          "height": 24
        }
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis",
      "deb",
      "rpm",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
