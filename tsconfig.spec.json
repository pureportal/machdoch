{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "vitest/globals"],
    "incremental": true,
    "tsBuildInfoFile": "./.cache/tsconfig.spec.tsbuildinfo"
  },
  "include": [
    "src/**/*.spec.ts"
  ],
  "exclude": [
    "src/tauri/ui/**/*.spec.ts",
    "src/tauri/ui/**/*.test.ts",
    "src/tauri/ui/**/*.test.tsx"
  ]
}
